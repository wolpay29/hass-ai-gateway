#!/command/with-contenv bashio
set -e

if ! bashio::config.true 'services.telegram_bot'; then
    bashio::log.info "[telegram-bot] disabled in config — sleeping"
    exec sleep infinity
fi

source /usr/lib/smarthome-assistant/export-env.sh

bashio::log.info "[telegram-bot] starting Telegram polling"
cd /opt/assistant/services/telegram_bot
exec python3 main.py
