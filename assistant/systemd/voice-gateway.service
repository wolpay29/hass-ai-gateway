[Unit]
Description=Voice Gateway for Home Assistant (RPi / ESP32 audio input)
After=network.target
Wants=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/smarthome/assistant/services/voice_gateway
Environment="PATH=/root/smarthome/assistant/services/telegram_bot/telegram_bot_env/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
ExecStart=/root/smarthome/assistant/services/telegram_bot/telegram_bot_env/bin/python /root/smarthome/assistant/services/voice_gateway/main.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
