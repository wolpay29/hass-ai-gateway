# ============================================================
# assistant/.env — entries relevant to the Voice Gateway
# The gateway reads from the shared assistant/.env file.
# Copy assistant/.env.example to assistant/.env and fill these in.
# ============================================================


# ------------------------------------------------------------
# Home Assistant (used to push Telegram receipts)
# ------------------------------------------------------------
BOT_TOKEN=your-telegram-bot-token
MY_CHAT_ID=123456789


# ------------------------------------------------------------
# Voice Gateway
# ------------------------------------------------------------
GATEWAY_PORT=8765
GATEWAY_API_KEY=              # set a shared secret; Raspberry Pi must send this as X-Api-Key header
GATEWAY_TELEGRAM_PUSH=true    # push a Telegram receipt for every command received


# ------------------------------------------------------------
# Whisper — speech-to-text
# "external" recommended: point to the faster-whisper Docker
# "local"    fallback:    runs faster-whisper in-process (CPU)
# ------------------------------------------------------------
WHISPER_BACKEND=external
WHISPER_EXTERNAL_URL=http://127.0.0.1:10300/v1/audio/transcriptions
WHISPER_EXTERNAL_MODEL=deepdml/faster-whisper-large-v3-turbo-ct2

# Local backend (only used when WHISPER_BACKEND=local)
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=de


# ------------------------------------------------------------
# TTS — text-to-speech (optional)
# When set, the gateway returns audio/wav to devices that send tts=true.
# Point to the tts_server Docker instance.
# Leave empty to return JSON instead of audio.
# ------------------------------------------------------------
TTS_EXTERNAL_URL=http://127.0.0.1:10400/tts
TTS_EXTERNAL_VOICE=de_DE-thorsten-low


# ------------------------------------------------------------
# LM Studio — LLM for command processing
# ------------------------------------------------------------
LMSTUDIO_URL=http://192.168.1.x:1234
LMSTUDIO_MODEL=qwen2.5-7b-instruct
LMSTUDIO_API_KEY=
LMSTUDIO_TIMEOUT=30
LMSTUDIO_TEMPERATURE=0.1
LMSTUDIO_NO_THINK=true

FALLBACK_MODE=2
LMSTUDIO_CONTEXT_LENGTH=8000
LMSTUDIO_MCP_ALLOWED_TOOLS=HassTurnOn,HassTurnOff,HassCancelAllTimers,HassBroadcast,HassClimateSetTemperature,HassLightSet,GetDateTime,GetLiveContext


# ------------------------------------------------------------
# Home Assistant
# ------------------------------------------------------------
HA_URL=http://192.168.1.x:8123
HA_TOKEN=your-long-lived-ha-token
