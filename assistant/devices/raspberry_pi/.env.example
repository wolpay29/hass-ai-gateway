# ============================================================
# Raspberry Pi voice client config
# Copy to .env and fill in your values.
# ============================================================


# ------------------------------------------------------------
# Voice Gateway — where the Pi sends audio commands
# ------------------------------------------------------------
GATEWAY_URL=http://192.168.1.x:8765
GATEWAY_API_KEY=              # must match GATEWAY_API_KEY on the server; leave empty if no auth

# Set this to your Telegram chat ID (numeric) to share conversation
# history with the Telegram bot. Any other string = isolated history.
DEVICE_ID=rpi-wohnzimmer


# ------------------------------------------------------------
# Audio devices — ALSA plughw format (same as arecord/aplay)
# Use "arecord -l" and "aplay -l" on the Pi to list available devices.
# Default: plughw:1,0 = ReSpeaker HAT on card 1
# ------------------------------------------------------------
ALSA_INPUT_DEVICE=plughw:1,0
ALSA_OUTPUT_DEVICE=plughw:1,0

# Speaker volume set at startup via amixer. Leave empty to skip.
SPEAKER_VOLUME=100%


# ------------------------------------------------------------
# Wake word (openwakeword)
# Built-in models: hey_jarvis, alexa, hey_mycroft, hey_rhasspy, timer, weather
# Or pass a path to a custom .onnx model file.
# ------------------------------------------------------------
WAKE_WORD=hey_jarvis   # most reliable built-in model. "alexa" is undertrained due to licensing restrictions.

# Detection threshold (0.0–1.0).
# Lower = more sensitive but more false positives.
WAKE_THRESHOLD=0.5


# ------------------------------------------------------------
# VAD — voice activity detection (recording after wake word)
# ------------------------------------------------------------
# RMS silence threshold (int16 units, 0–32767).
# Must be above your room's background noise floor but below speech level.
# Run with DEBUG=true and watch the recording rms= values to calibrate:
# set this just above the lowest values you see when the room is quiet.
# Typical range: 500 (quiet room) – 2000 (noisy room).
VAD_SILENCE_THRESHOLD=1500

# Seconds of silence before recording stops.
VAD_SILENCE_DURATION=1.0

# Maximum recording length in seconds.
VAD_MAX_DURATION=10.0


# ------------------------------------------------------------
# Local TTS fallback (only used when the gateway returns JSON
# instead of WAV, i.e. no TTS server configured server-side)
# ------------------------------------------------------------

# Path to a local Piper .onnx voice model.
# Download from: https://huggingface.co/rhasspy/piper-voices
# Leave empty to use pyttsx3/espeak instead.
TTS_MODEL=

# pyttsx3 speech rate (words per minute) — only used when TTS_MODEL is empty.
TTS_RATE=165


# ------------------------------------------------------------
# Debug — set to true to print score and RMS on every audio chunk.
# Useful for tuning WAKE_THRESHOLD and VAD_SILENCE_THRESHOLD.
# Disable once detection is working (very verbose).
# ------------------------------------------------------------
DEBUG=false
