                </mxCell>
                <mxCell id="stateFmt" value="core.llm.format_state_reply()&#xa;&#xa;2nd LLM call&#xa;Prompt: prompts.yaml::state_formatter&#xa;Turns raw HA values + transcript&#xa;into one short German sentence.&#xa;result.reply ← formatted output" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;fontSize=11;" parent="coreLane" vertex="1">
