                <mxCell id="legacyParse" value="core.llm.parse_command()&#xa;&#xa;LMSTUDIO_URL · LMSTUDIO_MODEL&#xa;LMSTUDIO_TEMPERATURE · LMSTUDIO_NO_THINK&#xa;LMSTUDIO_TIMEOUT · LMSTUDIO_API_KEY&#xa;Prompt: prompts.yaml::primary_parser&#xa;Catalog: core/entities.yaml (curated)&#xa;LLM_HISTORY_SIZE history injected&#xa;Validates entity_id against entities.yaml&#xa;Drops hallucinated IDs&#xa;MAX_ACTIONS_PER_COMMAND cap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;fontSize=11;" parent="coreLane" vertex="1">
                    <mxGeometry x="60" y="640" width="340" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="ragQuery" value="core.rag.index.query(embed_query)&#xa;&#xa;1) embeddings.embed_one(embed_query)&#xa;   → RAG_EMBED_URL · RAG_EMBED_MODEL&#xa;     RAG_EMBED_API_KEY · RAG_EMBED_TIMEOUT&#xa;     dim = RAG_EMBED_DIM&#xa;2) sqlite-vec KNN, k = RAG_TOP_K&#xa;   DB: RAG_DB_PATH&#xa;3) keyword boost: distance *= (1 - RAG_KEYWORD_BOOST)&#xa;   for entities whose curated keywords appear in transcript&#xa;4) returns top candidates with distances" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;fontSize=11;" parent="coreLane" vertex="1">
