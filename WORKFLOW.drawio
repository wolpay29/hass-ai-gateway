                <mxCell id="enrichBox" value="legacy enrichment&#xa;&#xa;if len(transcript.split()) ≤ 5:&#xa;  embed_query = recent_history + &#39; → &#39; + transcript&#xa;else:&#xa;  embed_query = transcript&#xa;&#xa;intent = &#39;command&#39;  (always)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;fontSize=11;" parent="coreLane" vertex="1">
