                    <mxGeometry x="1020" y="510" width="280" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="tgPushOut" value="📤 Telegram receipt to MY_CHAT_ID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=12;" parent="outLane" vertex="1">
                    <mxGeometry x="1490" y="450" width="320" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="errPanel" value="ERROR CODES (set on result.error)&#xa;&#xa;parse_failed            — LLM returned non-JSON&#xa;no_match                — primary path found nothing, FALLBACK_MODE=0&#xa;needs_fallback_no_mode  — parametric action requested, FALLBACK_MODE=0&#xa;fallback_no_match       — REST fallback found nothing&#xa;mcp_failed              — MCP fallback raised / no reply&#xa;smalltalk_failed        — smalltalk LLM call failed&#xa;no_speech               — gateway STT returned empty (audio path only)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="3500" width="700" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="paramPanel" value="KEY ENV PARAMETERS — what they control&#xa;&#xa;HA_URL · HA_TOKEN                — every Home Assistant call&#xa;LMSTUDIO_URL/MODEL/API_KEY      — default LLM (parser, smalltalk, state-formatter, MCP)&#xa;LMSTUDIO_TEMPERATURE/NO_THINK   — determinism + suppress &lt;think&gt; tags&#xa;LMSTUDIO_MCP_ALLOWED_TOOLS      — MCP whitelist (Mode 2)&#xa;LLM_HISTORY_SIZE                — turns kept per chat (0 = no history)&#xa;HISTORY_INCLUDE_ASSISTANT       — store assistant replies?&#xa;HISTORY_APPEND_EXECUTIONS       — append HA actions to assistant turn&#xa;MAX_ACTIONS_PER_COMMAND         — cap per request (0 = no cap)&#xa;FALLBACK_MODE                   — 0 off · 1 REST · 2 MCP&#xa;FALLBACK_REST_DOMAINS / MAX     — filter for REST fallback prompt&#xa;RAG_ENABLED                     — vector retrieval vs entities.yaml&#xa;RAG_TOP_K · RAG_KEYWORD_BOOST   — retrieval depth + keyword bias&#xa;RAG_EMBED_*                     — embedding endpoint (defaults to LMSTUDIO_*)&#xa;RAG_QUERY_REWRITE               — enable rewriter + intent classification&#xa;RAG_REWRITE_*                   — rewriter LLM endpoint (defaults to LMSTUDIO_*)&#xa;RAG_CLARIFY_GAP_THRESHOLD       — distance gap below which clarify (0 = off)&#xa;RAG_CLARIFY_SAME_DOMAIN_ONLY    — restrict clarification to same domain&#xa;TTS_EXTERNAL_URL/VOICE          — external TTS (gateway returns WAV when tts=true)&#xa;GATEWAY_API_KEY                 — gateway auth (X-Api-Key header)&#xa;GATEWAY_TELEGRAM_PUSH           — also push receipt to MY_CHAT_ID&#xa;WHISPER_BACKEND + WHISPER_*     — local vs external STT" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;align=left;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="800" y="3500" width="1100" height="500" as="geometry"/>
                </mxCell>
