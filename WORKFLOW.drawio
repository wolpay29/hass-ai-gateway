                <mxCell id="fbREST" value="parse_command_with_states()&#xa;&#xa;core.ha.get_all_states()&#xa;FALLBACK_REST_DOMAINS (filter)&#xa;FALLBACK_REST_MAX_ENTITIES (cap)&#xa;Prompt: prompts.yaml::fallback_rest&#xa;Uses prior_history snapshot&#xa;result.fallback_used = &#39;rest&#39;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;fontSize=11;" parent="coreLane" vertex="1">
                    <mxGeometry x="60" y="1800" width="320" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="fbMCP" value="core.llm_lmstudio.fallback_via_mcp()&#xa;&#xa;LM Studio + HA MCP server&#xa;LMSTUDIO_CONTEXT_LENGTH&#xa;LMSTUDIO_MCP_ALLOWED_TOOLS (whitelist)&#xa;LMSTUDIO_API_KEY (mandatory here)&#xa;result.reply = MCP text&#xa;result.fallback_used = &#39;mcp&#39;&#xa;errors → error=&#39;mcp_failed&#39;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;fontSize=11;" parent="coreLane" vertex="1">
                    <mxGeometry x="420" y="1800" width="320" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="fbErr" value="error =&#xa;needs_fallback_no_mode  (Mode 0)&#xa;or&#xa;fallback_no_match  (REST returned nothing)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;dashed=1;fontSize=11;" parent="coreLane" vertex="1">
                    <mxGeometry x="60" y="2010" width="320" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="execLoop" value="EXECUTE ACTIONS  (for each action in command.actions)&#xa;&#xa;safety re-check MAX_ACTIONS_PER_COMMAND&#xa;ignored items appended to result.actions_ignored&#xa;&#xa;if action == &#39;get_state&#39;:&#xa;    core.ha.get_state(entity_id)&#xa;    → push to state_queries[]&#xa;else:&#xa;    core.ha.call_service(domain, action, entity_id)&#xa;    → record success / failure&#xa;append to result.actions_executed[]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;fontSize=11;" parent="coreLane" vertex="1">
                    <mxGeometry x="1340" y="1640" width="380" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="histAppend" value="HISTORY_APPEND_EXECUTIONS=true ?&#xa;&#xa;append_execution_summary(chat_id):&#xa;&#39;ausgefuehrt: turn_on -&gt; light.licht_paul, ...&#39;&#xa;appended to last assistant turn so the LLM sees&#xa;what actually ran on the next turn." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;fontSize=11;" parent="coreLane" vertex="1">
                    <mxGeometry x="1340" y="1900" width="380" height="140" as="geometry"/>
                </mxCell>
