                <mxCell id="clarifyDec" value="parser response&#xa;&#xa;clarification_question set&#xa;AND actions == [] ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" parent="coreLane" vertex="1">
                    <mxGeometry x="1300" y="1340" width="380" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="clarify" value="LLM-driven clarification&#xa;&#xa;result.reply = clarification_question&#xa;result.actions_executed = []&#xa;append_clarification_turn(chat_id, ...)&#xa;→ original intent stays in history&#xa;   for the user&#39;s follow-up turn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;fontSize=11;" parent="coreLane" vertex="1">
                    <mxGeometry x="1730" y="1320" width="320" height="160" as="geometry"/>
