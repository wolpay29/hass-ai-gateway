# Copy this file to .env.local (gitignored) and fill in your real values.
# The runner reads .env.local once and merges per-run overrides from matrix.yaml
# on top of it. Your production .env stays untouched.

# --- Runner: Python executable for the gateway subprocess ---
# Only needed if you run the runner from a different venv than the gateway
# (e.g. telegram_bot_env). Leave empty for auto-detect.
# Example: GATEWAY_PYTHON=/usr/bin/python3
# Example: GATEWAY_PYTHON=/root/hass-ai-gateway/venv/bin/python
GATEWAY_PYTHON=

# --- Home Assistant ---
HA_URL=http://10.1.10.50:8123
HA_TOKEN=your-long-lived-ha-token

# --- LM Studio (chat + embeddings unless overridden below) ---
LMSTUDIO_URL=http://10.1.10.78:1234
LMSTUDIO_API_KEY=
LMSTUDIO_MODEL=qwen2.5-7b-instruct
LMSTUDIO_TIMEOUT=30
LMSTUDIO_TEMPERATURE=0.1
LMSTUDIO_NO_THINK=true
LMSTUDIO_CONTEXT_LENGTH=8000

# --- Whisper (external is required for the pipeline) ---
WHISPER_BACKEND=external
WHISPER_EXTERNAL_URL=http://10.1.10.78:10300/v1/audio/transcriptions
WHISPER_EXTERNAL_MODEL=deepdml/faster-whisper-large-v3-turbo-ct2
WHISPER_LANGUAGE=de

# --- Embedding model (defaults to LMSTUDIO_*) ---
RAG_EMBED_URL=
RAG_EMBED_API_KEY=
RAG_EMBED_TIMEOUT=
RAG_EMBED_MODEL=text-embedding-nomic-embed-text-v2-moe
RAG_EMBED_DIM=768

# --- TTS (optional - if empty, runner stores the JSON reply only, no audio) ---
TTS_EXTERNAL_URL=http://10.1.10.78:10400/tts
TTS_EXTERNAL_VOICE=de_DE-thorsten-low

# --- Telegram (intentionally blank for the test pipeline) ---
BOT_TOKEN=
MY_CHAT_ID=0
GATEWAY_TELEGRAM_PUSH=false
