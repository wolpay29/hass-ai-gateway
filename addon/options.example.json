{
  "language": "de",

  "services": {
    "voice_gateway": true,
    "notify_gateway": true,
    "telegram_bot": true
  },

  "telegram": {
    "bot_token": "REPLACE_ME",
    "chat_id": 123456789
  },

  "home_assistant": {
    "url": "http://supervisor/core",
    "token": "",
    "service_timeout": 15,
    "dry_run": false
  },

  "lmstudio": {
    "url": "http://192.168.1.10:1234",
    "model": "qwen2.5-7b-instruct",
    "api_key": "",
    "timeout": 30,
    "temperature": 0.1,
    "no_think": true,
    "context_length": 8000,
    "mcp_allowed_tools": "HassTurnOn,HassTurnOff,HassCancelAllTimers,HassBroadcast,HassClimateSetTemperature,HassLightSet,GetDateTime,GetLiveContext",
    "max_actions_per_command": 0
  },

  "whisper": {
    "url": "http://192.168.1.10:10300/v1/audio/transcriptions",
    "model": "deepdml/faster-whisper-large-v3-turbo-ct2"
  },

  "tts": {
    "url": "http://192.168.1.10:10400/tts",
    "voice": "de_DE-thorsten-low"
  },

  "gateways": {
    "voice_port": 8765,
    "voice_api_key": "",
    "voice_telegram_push": true,
    "voice_reply_with_transcript": true,
    "notify_port": 8766,
    "notify_http_timeout": 10
  },

  "rag": {
    "enabled": true,
    "top_k": 15,
    "distance_threshold": 0.0,
    "keyword_boost": 0.3,
    "embed_url": "",
    "embed_api_key": "",
    "embed_model": "text-embedding-nomic-embed-text-v2-moe",
    "embed_dim": 768
  },

  "preprocessor": {
    "enabled": true,
    "url": "",
    "api_key": "",
    "model": "",
    "timeout": 30,
    "temperature": 0.1
  },

  "advanced": {
    "fallback_mode": 0,
    "fallback_rest_max_entities": 0,
    "fallback_rest_domains": "light,switch,sensor,binary_sensor,climate,automation,cover",
    "history_size": 0,
    "history_include_assistant": true,
    "history_append_executions": false
  }
}
