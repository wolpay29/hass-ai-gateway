# ============================================================
# .env.example
# Copy to .env and fill in your values.
# Never commit the real .env — it is git-ignored.
# Note: do NOT use inline comments (key=value # comment) —
# systemd's EnvironmentFile does not strip them and will
# include the comment text as part of the value.
# ============================================================


# ------------------------------------------------------------
# Telegram Bot
# ------------------------------------------------------------
BOT_TOKEN=your-telegram-bot-token

# Your personal Telegram chat ID
MY_CHAT_ID=123456789


# ------------------------------------------------------------
# Home Assistant
# ------------------------------------------------------------
HA_URL=http://192.168.1.x:8123
HA_TOKEN=your-long-lived-ha-token


# ------------------------------------------------------------
# Battery monitor (Telegram Bot)
# ------------------------------------------------------------

# How often to poll battery state (seconds)
CHECK_INTERVAL_SECONDS=300

# Notify when battery exceeds this percentage
BATTERY_THRESHOLD=80


# ------------------------------------------------------------
# Whisper — speech-to-text
# Backend: "local"    = faster-whisper runs on this machine
#          "external" = send audio to a remote Whisper HTTP API
# ------------------------------------------------------------
WHISPER_BACKEND=external

# Local backend settings (only used when WHISPER_BACKEND=local)
# Model size: tiny / base / small / medium / large
WHISPER_MODEL=small
# Inference device: cpu or cuda
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_THREADS=4
WHISPER_BEAM_SIZE=1
WHISPER_LANGUAGE=de

# External backend settings (only used when WHISPER_BACKEND=external)
WHISPER_EXTERNAL_URL=http://192.168.1.x:10300/v1/audio/transcriptions
WHISPER_EXTERNAL_MODEL=deepdml/faster-whisper-large-v3-turbo-ct2

# Echo recognised text back in Telegram
VOICE_REPLY_WITH_TRANSCRIPT=true
VOICE_DOWNLOAD_DIR=data/voice


# ------------------------------------------------------------
# LM Studio — local LLM (OpenAI-compatible /v1 API)
# Used for command parsing, state replies, and MCP fallback.
# ------------------------------------------------------------
LMSTUDIO_URL=http://192.168.1.x:1234
LMSTUDIO_MODEL=qwen2.5-7b-instruct
LMSTUDIO_TIMEOUT=30

# Required only when LM Studio auth is enabled
LMSTUDIO_API_KEY=

# Model quality / speed tuning
LMSTUDIO_TEMPERATURE=0.1

# Suppress <think> blocks (reasoning models)
LMSTUDIO_NO_THINK=true

# Context window for MCP mode (Mode 2)
LMSTUDIO_CONTEXT_LENGTH=8000


# ------------------------------------------------------------
# Conversation history
# ------------------------------------------------------------

# 0 = disabled; N = keep last N user turns
LLM_HISTORY_SIZE=0
HISTORY_INCLUDE_ASSISTANT=true
HISTORY_APPEND_EXECUTIONS=false


# ------------------------------------------------------------
# Command limits
# ------------------------------------------------------------

# 0 = no limit
MAX_ACTIONS_PER_COMMAND=0


# ------------------------------------------------------------
# Fallback mode — what to do when no entity matches
#   0 = return an error message (default, safest)
#   1 = fetch all live HA entities via REST and ask the LLM again
#   2 = use LM Studio MCP integration (requires LM Studio auth + HA MCP server)
# ------------------------------------------------------------
FALLBACK_MODE=0

# 0 = no limit (Mode 1 only)
FALLBACK_REST_MAX_ENTITIES=0
FALLBACK_REST_DOMAINS=light,switch,sensor,binary_sensor,climate,automation,cover


# ------------------------------------------------------------
# RAG mode — semantic entity retrieval (replaces entities.yaml lookup)
# Requires an embedding model served by LM Studio.
# ------------------------------------------------------------
RAG_ENABLED=false
RAG_DB_PATH=data/rag/entities.sqlite
RAG_TOP_K=15
RAG_KEYWORD_BOOST=0.3

# Embedding model (defaults to the same LM Studio instance as the chat model)
RAG_EMBED_URL=http://192.168.1.x:1234

# Defaults to LMSTUDIO_API_KEY if empty
RAG_EMBED_API_KEY=

# Defaults to LMSTUDIO_TIMEOUT if empty
RAG_EMBED_TIMEOUT=30
RAG_EMBED_MODEL=text-embedding-nomic-embed-text-v2-moe
RAG_EMBED_DIM=768

# LLM Preprocessor — extra (small) LLM call before the main pipeline.
# Classifies intent (command | smalltalk), fixes typos / STT errors, and
# resolves pronouns from history. Works independently of RAG_ENABLED.
# Each setting falls back to the matching LMSTUDIO_* value if empty.
LLM_PREPROCESSOR=false
LLM_PREPROCESSOR_URL=
LLM_PREPROCESSOR_API_KEY=
LLM_PREPROCESSOR_MODEL=
LLM_PREPROCESSOR_TIMEOUT=30
LLM_PREPROCESSOR_TEMPERATURE=0.1

# ------------------------------------------------------------
# MCP tool whitelist (Mode 2 only)
# Leave empty to allow all tools the HA MCP server exposes.
# ------------------------------------------------------------
LMSTUDIO_MCP_ALLOWED_TOOLS=HassTurnOn,HassTurnOff,HassCancelAllTimers,HassBroadcast,HassClimateSetTemperature,HassLightSet,GetDateTime,GetLiveContext


# ------------------------------------------------------------
# Voice Gateway (services/voice_gateway)
# ------------------------------------------------------------

# Shared secret between gateway and RPi. Leave empty for no auth.
GATEWAY_API_KEY=
GATEWAY_PORT=8765

# Send a Telegram receipt for every voice command
GATEWAY_TELEGRAM_PUSH=true


# ------------------------------------------------------------
# TTS — text-to-speech synthesis (used by voice_gateway)
# Point to the tts_server Docker instance.
# Leave empty to disable TTS (gateway returns JSON instead of WAV).
# ------------------------------------------------------------
TTS_EXTERNAL_URL=http://192.168.1.x:10400/tts
TTS_EXTERNAL_VOICE=de_DE-thorsten-low
